# Supabase Configuration
# Get these values from your Supabase project dashboard
# https://app.supabase.com/project/_/settings/api

# The URL of your Supabase project (e.g., https://xxxxx.supabase.co)
VITE_SUPABASE_URL=https://your-project.supabase.co

# The anonymous key from Supabase (safe to expose in client-side code)
# This is different from the service_role key - use the "anon" key
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Password hashing salt (change this in production!)
# Used for local admin password hashing when Supabase Auth is not available
VITE_PASSWORD_SALT=your-secure-salt-here-change-in-production

# Optional: Firebase Configuration (DEPRECATED - no longer needed)
# If you were using Firebase before, you can remove these
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
